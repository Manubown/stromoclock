# Neon Postgres connection string (https://neon.tech)
DATABASE_URL=postgres://user:password@ep-xxx.eu-central-1.aws.neon.tech/stromoclock?sslmode=require

# ENTSO-E Transparency Platform API token.
# OPTIONAL — only required if you serve users outside AT / DE-LU bidding zones.
# AT and DE-LU use the free aWATTar API and need no token.
# To get a token: register at https://transparency.entsoe.eu, then email
# transparency@entsoe.eu from your registered address asking for "Restful API" access.
ENTSOE_API_TOKEN=

# Resend (https://resend.com) — magic-link email
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cookie signing secret. Generate with: openssl rand -base64 48
SESSION_COOKIE_SECRET=

# Public app URL (used to build magic-link verify URLs)
APP_URL=http://localhost:3000

# Bearer token for the daily-digest cron endpoint.
# Vercel Cron sends this automatically when set as a Vercel env var.
# Generate with: openssl rand -base64 32
CRON_SECRET=
